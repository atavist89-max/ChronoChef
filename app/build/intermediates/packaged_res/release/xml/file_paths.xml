<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- External storage for model download -->
    <external-path
        name="external_files"
        path="Android/data/com.fruitid/files/" />
    
    <external-cache-path
        name="external_cache"
        path="Android/data/com.fruitid/cache/" />
    
    <!-- Internal app storage -->
    <files-path
        name="internal_files"
        path="." />
    
    <cache-path
        name="internal_cache"
        path="." />
    
    <!-- Thumbnails directory -->
    <files-path
        name="thumbnails"
        path="thumbnails/" />
</paths>
